{
  "name": "@kozmof/reed",
  "version": "1.0.0",
  "private": false,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/reed.js",
  "module": "./dist/reed.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/reed.js"
    }
  },
  "scripts": {
    "build": "tsc && vite build && tsc -p tsconfig.types.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:perf:watch": "vitest --config vitest.perf.config.ts",
    "coverage": "vitest run --coverage",
    "gen-fixture": "npx tsx test-utils/gen-fixture.ts",
    "bench": "npx tsx test-utils/benchmarks/bench.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "pack:home": "pnpm pack --pack-destination ~",
    "pack:check": "pnpm pack:home && pnpm pack:check-compare",
    "preflight": "pnpm publish --dry-run",
    "pack:check-name": "v=$(echo $npm_package_version) && name='kozmof-reed-'$v && echo $name",
    "pack:check-counts": "name=$(pnpm run --silent pack:check-name) && echo $(tar -tzf ~/$name.tgz | wc -l)",
    "pack:check-compare": "counts=$(pnpm run --silent pack:check-counts) && if [ $counts -ne 97 ]; then echo ERROR: check files in tgz; exit 1; else echo OK; fi"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "4.0.18",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
